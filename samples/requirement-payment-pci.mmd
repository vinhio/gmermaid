requirementDiagram
    direction LR

    requirement pci_compliance {
        id: REQ-1
        text: System shall be PCI-DSS Level 1
        risk: High
        verifymethod: Inspection
    }
    functionalRequirement tokenize {
        id: FR-1
        text: Tokenize PAN before storage
        risk: High
        verifymethod: Test
    }
    functionalRequirement encrypt {
        id: FR-2
        text: Encrypt data in transit (TLS 1.3)
        risk: High
        verifymethod: Test
    }
    performanceRequirement throughput {
        id: PR-1
        text: 2000 transactions per second
        risk: Medium
        verifymethod: Demonstration
    }
    designConstraint hsm {
        id: DC-1
        text: Keys in FIPS 140-2 HSM
        risk: Low
        verifymethod: Inspection
    }

    element gateway {
        type: Service
        docref: arch/gateway.md
    }
    element vault {
        type: Service
        docref: arch/vault.md
    }

    pci_compliance - contains -> tokenize
    pci_compliance - contains -> encrypt
    tokenize - derives -> hsm
    throughput - refines -> pci_compliance
    tokenize - satisfies -> gateway
    encrypt - satisfies -> gateway
    hsm - satisfies -> vault
    vault <- verifies - hsm
    gateway - traces -> pci_compliance

    classDef high fill:#7a1f1f
    class pci_compliance,tokenize,encrypt high
